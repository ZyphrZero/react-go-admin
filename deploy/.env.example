# =============================================================================
# React Go Admin Docker environment example
# =============================================================================

# -----------------------------------------------------------------------------
# Port mapping
# -----------------------------------------------------------------------------
BIND_HOST=0.0.0.0
APP_PORT=8080

# -----------------------------------------------------------------------------
# App runtime
# -----------------------------------------------------------------------------
APP_ENV=prod
VERSION=0.1.0
APP_TITLE=React Go Admin
PROJECT_NAME=React Go Admin
APP_DESCRIPTION=Modern admin system built with Go and React
DEBUG=false
HOST=0.0.0.0
PORT=9999
TZ=Asia/Shanghai

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOGS_ROOT=logs
LOG_RETENTION_DAYS=7
LOG_ROTATION=1 day
LOG_MAX_FILE_SIZE=10 MB
LOG_ENABLE_ACCESS_LOG=true
DISABLE_AUTO_MIGRATE=false

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Use "*" for same-origin deployment.
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=replace_with_a_secure_random_64_char_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_SECURE=true
REFRESH_TOKEN_COOKIE_SAMESITE=lax

# -----------------------------------------------------------------------------
# Initial admin account
# -----------------------------------------------------------------------------
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_NICKNAME=admin
INITIAL_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
DB_CONNECTION=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=react_go_admin
DB_PASSWORD=change_me
DB_DATABASE=react_go_admin

POSTGRES_USER=react_go_admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=react_go_admin

# -----------------------------------------------------------------------------
# Password policy
# -----------------------------------------------------------------------------
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=true

# -----------------------------------------------------------------------------
# UI notification defaults
# -----------------------------------------------------------------------------
NOTIFICATION_POSITION=top-right
NOTIFICATION_DURATION=4000
NOTIFICATION_VISIBLE_TOASTS=3
