# =============================================================================
# React Go Admin environment example
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=dev
VERSION=0.1.0
APP_TITLE=React Go Admin
PROJECT_NAME=React Go Admin
APP_DESCRIPTION=Modern admin system built with Go and React
DEBUG=false
HOST=0.0.0.0
PORT=9999

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOGS_ROOT=logs
LOG_RETENTION_DAYS=7
LOG_ROTATION=1 day
LOG_MAX_FILE_SIZE=10 MB
LOG_ENABLE_ACCESS_LOG=true
DISABLE_AUTO_MIGRATE=false
ENABLE_INIT_API=true

# -----------------------------------------------------------------------------
# Initial admin bootstrap
# -----------------------------------------------------------------------------
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_NICKNAME=admin
# Leave empty to auto-generate a one-time password during bootstrap.
INITIAL_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=replace_with_a_random_64_char_secret_key_before_startup
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAMESITE=lax

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_CONNECTION=sqlite
DB_FILE=db.sqlite3

# MySQL / PostgreSQL (used when DB_CONNECTION is mysql or postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=react_go_admin

# -----------------------------------------------------------------------------
# Password policy
# -----------------------------------------------------------------------------
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=true

# -----------------------------------------------------------------------------
# UI notification defaults
# -----------------------------------------------------------------------------
NOTIFICATION_POSITION=top-right
NOTIFICATION_DURATION=4000
NOTIFICATION_VISIBLE_TOASTS=3
